# Monorepo ignores for Kulan app

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/build/
**/coverage/
**/.nyc_output/

# Expo / React Native
**/.expo/
**/.expo-shared/
**/web-build/
**/.metro-health-check*
**/expo-env.d.ts
**/android/
**/ios/

# TypeScript cache
**/*.tsbuildinfo

# Env files
**/.env
**/.env.*.local
**/.env.local

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# OS / Editor
**/.DS_Store
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Temporary files
**/.temp/
**/.tmp/

# Keep backend nested git backup out of monorepo
kulan-nest-backend/.git_backup_before_monorepo/
