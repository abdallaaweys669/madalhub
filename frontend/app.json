{
  "expo": {
    "name": "MadalHub",
    "slug": "madalhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "whatsapp-api"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "package": "com.madalhub.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow MadalHub to access your camera to take a profile photo.",
          "microphonePermission": false,
          "photosPermission": "Allow MadalHub to access your photos to set a profile photo."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MadalHub to scan attendee ticket QR codes at the door."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow MadalHub to access your location to show nearby events."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow MadalHub to save your ticket QR code to your photo library.",
          "savePhotosPermission": "Allow MadalHub to save your ticket QR code to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-image"
    ],
    "scheme": "madalhub",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f1dc3a9-41f0-4b9d-8f27-feb555a4928c"
      }
    },
    "owner": "abdallaaweis669"
  }
}
