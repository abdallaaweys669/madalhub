# Copy this file to .env and set real values (never commit .env).
# Expo requires EXPO_PUBLIC_* for variables exposed to the app bundle.

# Base URL of the Nest API (no trailing slash).
# On a phone: use your PC Wi‑Fi IPv4 from `ipconfig` (e.g. http://10.182.24.20:3000), not 127.0.0.1
EXPO_PUBLIC_API_BASE_URL=http://10.182.24.20:3000

# Clerk publishable key (Dashboard -> API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Enable Google Places API + Geocoding API + Place Details for venue search and GPS district detection.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
