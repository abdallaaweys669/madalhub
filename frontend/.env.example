# Copy this file to .env and set real values (never commit .env).
# Expo requires EXPO_PUBLIC_* for variables exposed to the app bundle.

# Base URL of the Nest API (no trailing slash), e.g. http://192.168.1.5:3000 or https://your-ngrok-url.ngrok-free.app
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000

# Clerk publishable key (Dashboard -> API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Optional but strongly recommended for accurate venue autocomplete / campuses / branches.
# Enable Google Places API + Places Details API for this key.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
