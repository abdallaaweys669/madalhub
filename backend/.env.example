# Copy this file to .env and set real values (never commit .env).

PORT=3000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
# Email OTP (Resend — https://resend.com)
# Dev: use onboarding@resend.dev (only delivers to your Resend account email)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Clerk (https://dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY=

# Organizer publish payments (mobile money — manual admin approval)
ORGANIZER_PAYMENT_PHONE=+252XXXXXXXXX
PUBLISH_PRICE_SINGLE=5
PUBLISH_PRICE_BUNDLE=20
PUBLISH_BUNDLE_CREDITS=5
